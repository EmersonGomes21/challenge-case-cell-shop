# Example environment variables for local development
# Copy to .env and adjust values; do NOT commit secrets.

# Full database connection URL (Postgres)
DATABASE_URL=postgresql://postgres:password@db:5432/casecellshop

# Individual DB parts (used by entrypoint and docker-compose)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=casecellshop

# Entrypoint controls
RUN_MIGRATIONS=true
RUN_SEED=true

# Optional tuning
WAIT_TIMEOUT=120

